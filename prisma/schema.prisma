generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  VIEWER
}

enum SettingScope {
  USER
  SYSTEM
}

enum TagType {
  GLOBAL
  DIARY
  NOTE
  TODO
  FILE
}

enum TodoStatus {
  OPEN
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StorageProvider {
  LOCAL
  R2
  S3
  SUPABASE
}

enum FileVisibility {
  PRIVATE
  PUBLIC
}

enum EntityType {
  TODO
  NOTE
  DIARY
  FILE
}

enum AIStatus {
  COMPLETED
  FAILED
}

enum AIModule {
  DASHBOARD
  TODOS
  NOTES
  DIARY
  FILES
  AI
}

enum AIIntent {
  CHAT
  SUMMARIZE_DIARY
  PLAN_TODOS
  ORGANIZE_FILES
  STUDY_ASSISTANT
  SEARCH_KNOWLEDGE
}

enum ExamQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum ExamDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamPracticeMode {
  SEQUENTIAL
  RANDOM
  WRONG_ONLY
}

enum ExamSourceStatus {
  PARSING
  READY
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  role         UserRole @default(OWNER)
  avatarFileId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  aiHistory AIHistory[]
  diaries   Diary[]
  files     FileAsset[]
  notes     Note[]
  settings  Setting[]
  tags      Tag[]
  todos     Todo[]

  examAnswers         ExamAnswer[]
  examKnowledgePoints ExamKnowledgePoint[]
  examPracticeSessions ExamPracticeSession[]
  examQuestions       ExamQuestion[]
  examSources         ExamSource[]
  examWrongRecords    ExamWrongRecord[]
}

model Setting {
  id        String       @id @default(cuid())
  userId    String
  key       String
  valueJson Json
  scope     SettingScope @default(USER)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([scope])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String
  type      TagType  @default(GLOBAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entityLinks TagOnEntity[]
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
  @@index([type])
}

model Todo {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  status      TodoStatus @default(OPEN)
  priority    Priority   @default(MEDIUM)
  dueAt       DateTime?
  completedAt DateTime?
  parentId    String?
  project     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  children Todo[] @relation("TodoHierarchy")
  parent   Todo?  @relation("TodoHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, priority])
  @@index([dueAt])
}

model Note {
  id              String   @id @default(cuid())
  userId          String
  title           String
  contentMarkdown String
  contentText     String
  pinned          Boolean  @default(false)
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pinned, archived])
}

model Diary {
  id              String   @id @default(cuid())
  userId          String
  title           String
  contentMarkdown String
  contentText     String
  mood            String?
  weather         String?
  diaryDate       DateTime
  favorite        Boolean  @default(false)
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, diaryDate])
  @@index([userId, diaryDate])
  @@index([userId, favorite, archived])
}

model FileAsset {
  id              String          @id @default(cuid())
  userId          String
  filename        String
  originalName    String
  mimeType        String
  size            BigInt
  checksum        String?
  storageProvider StorageProvider @default(LOCAL)
  storageKey      String
  visibility      FileVisibility  @default(PRIVATE)
  metadataJson    Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  entityLinks FileOnEntity[]
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storageProvider, storageKey])
  @@index([userId, mimeType])
}

model AIHistory {
  id                String      @id @default(cuid())
  userId            String
  module            AIModule
  intent            AIIntent
  inputJson         Json
  outputJson        Json?
  model             String?
  status            AIStatus
  relatedEntityType EntityType?
  relatedEntityId   String?
  createdAt         DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, module, intent])
  @@index([relatedEntityType, relatedEntityId])
}

model TagOnEntity {
  id         String     @id @default(cuid())
  tagId      String
  entityType EntityType
  entityId   String
  createdAt  DateTime   @default(now())

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
}

model FileOnEntity {
  id           String     @id @default(cuid())
  fileId       String
  entityType   EntityType
  entityId     String
  relationType String     @default("attachment")
  createdAt    DateTime   @default(now())

  file FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, entityType, entityId, relationType])
  @@index([entityType, entityId])
}

model ExamSource {
  id           String           @id @default(cuid())
  userId       String
  title        String
  filename     String
  mimeType     String
  size         BigInt
  contentText  String
  contentHash  String?
  status       ExamSourceStatus @default(READY)
  errorMessage String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  answers         ExamAnswer[]
  knowledgePoints ExamKnowledgePoint[]
  practiceSessions ExamPracticeSession[]
  questions       ExamQuestion[]
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  wrongRecords    ExamWrongRecord[]

  @@index([userId, status, createdAt])
  @@index([userId, contentHash])
}

model ExamKnowledgePoint {
  id         String         @id @default(cuid())
  userId     String
  sourceId   String
  title      String
  summary    String
  difficulty ExamDifficulty @default(MEDIUM)
  orderIndex Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  answers      ExamAnswer[]
  questions    ExamQuestion[]
  source       ExamSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wrongRecords ExamWrongRecord[]

  @@index([userId, sourceId, orderIndex])
  @@index([userId, difficulty])
}

model ExamQuestion {
  id               String           @id @default(cuid())
  userId           String
  sourceId         String
  knowledgePointId String?
  type             ExamQuestionType
  difficulty       ExamDifficulty   @default(MEDIUM)
  stem             String
  optionsJson      Json?
  answerJson       Json
  explanation      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  answers        ExamAnswer[]
  knowledgePoint ExamKnowledgePoint? @relation(fields: [knowledgePointId], references: [id], onDelete: SetNull)
  source         ExamSource          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  wrongRecords   ExamWrongRecord[]

  @@index([userId, sourceId, type, difficulty])
  @@index([knowledgePointId])
}

model ExamPracticeSession {
  id        String           @id @default(cuid())
  userId    String
  sourceId  String?
  mode      ExamPracticeMode
  questionOrderJson Json
  total     Int              @default(0)
  correct   Int              @default(0)
  score     Float            @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  answers ExamAnswer[]
  source  ExamSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mode, createdAt])
  @@index([sourceId])
}

model ExamAnswer {
  id               String   @id @default(cuid())
  userId           String
  sessionId        String
  questionId       String
  sourceId         String
  knowledgePointId String?
  answerJson       Json
  isCorrect        Boolean
  createdAt        DateTime @default(now())

  knowledgePoint ExamKnowledgePoint?  @relation(fields: [knowledgePointId], references: [id], onDelete: SetNull)
  question       ExamQuestion         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session        ExamPracticeSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  source         ExamSource           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([userId, isCorrect, createdAt])
  @@index([knowledgePointId])
}

model ExamWrongRecord {
  id               String   @id @default(cuid())
  userId           String
  questionId       String
  sourceId         String
  knowledgePointId String?
  wrongCount       Int      @default(1)
  lastAnswerJson   Json?
  lastWrongAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  knowledgePoint ExamKnowledgePoint? @relation(fields: [knowledgePointId], references: [id], onDelete: SetNull)
  question       ExamQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  source         ExamSource          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, lastWrongAt])
  @@index([knowledgePointId])
}
